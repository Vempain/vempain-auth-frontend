{
  "extends" : "./tsconfig.app.json",
  "compilerOptions" : {
    "esModuleInterop" : true,
    "lib" : [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module" : "CommonJS",
    "moduleResolution" : "node",
    "types" : [
      "jest",
      "node"
    ],
    "verbatimModuleSyntax" : false,
    "noEmit" : true
  },
  "include" : [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}

