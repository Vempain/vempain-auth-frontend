{
  "name": "@vempain/vempain-auth-frontend",
  "type": "module",
  "version": "0.9.0",
  "description": "Vempain authorization and session handling for the frontend",
  "author": "Paul-Erik Törrönen",
  "homepage": "https://vempain.poltsi.fi",
  "license": "GPL-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "prebuild": "node generateBuildInfo.js",
    "build": "tsc -p tsconfig.build.json",
    "build:stage": "yarn prebuild && tsc -p tsconfig.build.json",
    "build:production": "yarn prebuild && tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage ."
  },
  "dependencies": {
    "antd" : "^6.3.0",
    "dayjs": "^1.11.19",
    "env-cmd": "^11.0.0",
    "jsonwebtoken" : "^9.0.3",
    "react-router": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "axios": "^1.13.5",
    "react": "^19.2.4",
    "react-dom" : "^19.2.4",
    "react-router-dom" : "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/react" : "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.13.5",
    "eslint" : "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.6",
    "typescript-eslint": "^8.56.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vempain/vempain-auth-frontend.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
