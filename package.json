  "dependencies" : {
    "antd" : "^6.4.3",
    "dayjs" : "^1.11.21"
  },
  "peerDependencies" : {
    "axios" : "1.16.1",
    "react" : "^19.2.5",
    "react-dom" : "^19.2.5",
    "react-router-dom" : "^7.14.1"
  },
  "devDependencies" : {
    "@eslint/js" : "^10.0.1",
    "@testing-library/jest-dom" : "^6.9.1",
    "@types/jest" : "^30.0.0",
    "@types/react" : "^19.2.16",
    "@types/react-dom" : "^19.2.3",
    "axios" : "1.16.1",
    "eslint" : "^10.4.1",
    "eslint-plugin-react-hooks" : "^7.1.1",
    "eslint-plugin-react-refresh" : "^0.5.2",
    "jest" : "^30.4.2",
    "jest-environment-jsdom" : "^30.4.1",
    "react" : "^19.2.7",
    "react-dom" : "^19.2.7",
    "react-router-dom" : "^7.16.0",
    "ts-jest" : "^29.4.11",
    "typescript" : "^6.0.3",
    "typescript-eslint" : "^8.60.1"
  },
  "repository" : {
    "type" : "git",
    "url" : "git+https://github.com/Vempain/vempain-auth-frontend.git"
