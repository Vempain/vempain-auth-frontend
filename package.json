{
  "name" : "@vempain/vempain-auth-frontend",
  "type" : "module",
  "version" : "0.9.0",
  "description" : "Vempain authorization and session handling for the frontend",
  "author" : "Paul-Erik Törrönen",
  "homepage" : "https://vempain.poltsi.fi",
  "license" : "GPL-2.0",
  "main" : "./dist/index.js",
  "module" : "./dist/index.js",
  "types" : "./dist/index.d.ts",
  "exports" : {
